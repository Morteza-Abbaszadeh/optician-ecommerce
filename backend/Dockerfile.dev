FROM python:3.11-slim

WORKDIR /app

# Prevent Python from writing pyc files and keep stdout unbuffered
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Install system dependencies (required for psycopg2/Postgres)
RUN apt-get update \
    && apt-get install -y gcc libpq-dev \
    && apt-get clean

# We will mount the source code via docker-compose, 
# but we need requirements to install dependencies.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Command is handled by docker-compose for dev, but we set a default
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]